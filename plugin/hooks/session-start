#!/usr/bin/env bash
# SessionStart hook for the sdcorejs-agent plugin.
# Injects the sdcorejs-using-skills bootstrap so dispatch discipline holds
# even in a foreign project that has no sdcorejs CLAUDE.md.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# The bootstrap skill is mirrored to plugin/skills/ by .claude/sync-skills.sh.
bootstrap_path="${PLUGIN_ROOT}/skills/sdcorejs-using-skills/SKILL.md"
bootstrap_content=$(cat "$bootstrap_path" 2>&1 || echo "Error reading sdcorejs-using-skills skill")

# Escape for JSON embedding via bash parameter substitution (single C-level
# pass each — far faster than a char-by-char loop).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

bootstrap_escaped=$(escape_for_json "$bootstrap_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have the sdcorejs SDLC skill pack.\n\n**Below is the full content of your 'sdcorejs-using-skills' bootstrap — how to find and dispatch sdcorejs skills. For all other skills, use the 'Skill' tool:**\n\n${bootstrap_escaped}\n</EXTREMELY_IMPORTANT>"

# Emit only the field the current platform consumes.
# Uses printf (not heredoc) to avoid a bash 5.3+ heredoc hang.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
