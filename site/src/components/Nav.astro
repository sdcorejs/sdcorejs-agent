---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<header class="nav">
  <a class="brand" href={`${base}/`} aria-label="SDCoreJS Agent — go to home">
    <img src={`${base}/logo-text.png`} alt="SDCoreJS" />
  </a>

  <nav class="links" aria-label="Section navigation">
    <a href={`${base}/#tracks`}>Tracks</a>
    <a href={`${base}/angular-portal`}>Angular Portal</a>
    <a href={`${base}/#install`}>Install</a>
    <a
      class="github"
      href="https://github.com/sdcorejs/sdcorejs-agent"
      target="_blank"
      rel="noreferrer"
      aria-label="GitHub repository"
    >
      <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
        <path
          fill="currentColor"
          d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38v-1.34c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.51-1.08-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.22 2.2.82a7.59 7.59 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.28.82 2.15 0 3.07-1.86 3.75-3.64 3.95.29.25.54.74.54 1.5v2.22c0 .21.15.46.55.38A8 8 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
        ></path>
      </svg>
      <span>GitHub</span>
    </a>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 14px clamp(20px, 4vw, 48px);
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid transparent;
    transition:
      border-color 220ms var(--ease),
      box-shadow 220ms var(--ease),
      background 220ms var(--ease);
  }

  /* Subtle border + shadow once user scrolls past hero */
  .nav:not(:has(~ * .hero:hover)) {
    /* placeholder — actual scrolled state could be added via JS if needed */
  }

  .brand {
    display: inline-flex;
    align-items: center;
  }

  .brand img {
    height: 32px;
    width: auto;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .links a {
    padding: 8px 14px;
    color: var(--c-text-soft);
    font-size: 0.92rem;
    font-weight: 500;
    border-radius: 999px;
    transition:
      color 160ms var(--ease),
      background 160ms var(--ease);
  }

  .links a:hover {
    color: var(--c-text);
    background: var(--c-bg-soft);
  }

  .links .github {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-left: 6px;
    padding: 8px 14px;
    color: var(--c-text);
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
  }

  .links .github:hover {
    background: var(--c-text);
    color: #fff;
    border-color: var(--c-text);
  }

  /* Mobile — collapse non-essential links, keep brand + GitHub */
  @media (max-width: 640px) {
    .links a:not(.github) {
      display: none;
    }
  }
</style>
