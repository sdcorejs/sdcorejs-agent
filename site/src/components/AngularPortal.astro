---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const packs = [
  ["init-portal", "Bootstrap a portal with environments and Core UI defaults"],
  ["admin-screens", "Always-on account, role, and permission screens"],
  ["init-module", "Create feature module boundaries and route wiring"],
  ["init-entity", "Generate full CRUD model, service, routes, and tests"],
  ["screen-list", "Build table screens with filters, paging, and actions"],
  ["screen-detail", "Build CREATE / UPDATE / DETAIL form states"],
  ["actions", "Add workflow, bulk, export, and side-effect buttons"],
];

const flow = [
  "brainstorming",
  "spec",
  "plan",
  "execute-plan",
  "angular",
  "finish gates",
];
---

<section id="angular" class="ap">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow"
        ><span class="bullet" aria-hidden="true"></span>Track focus</span
      >
      <h2>Angular Portal - full CRUD with Core UI first</h2>
      <p class="lead">
        The Angular track is now a single write-code orchestrator backed by
        focused reference packs. It prefers <a
          href="https://www.npmjs.com/package/@sdcorejs/angular"
          target="_blank"
          rel="noopener"><code>@sdcorejs/angular</code></a
        > components, keeps generated labels runtime-localized, and runs through
        the shared SDLC gates and finish checks before code is handed off.
      </p>
    </div>

    <div class="flow reveal delay-1" aria-label="SDLC workflow">
      {
        flow.map((name, i) => (
          <Fragment>
            <span class="flow-step">{name}</span>
            {i < flow.length - 1 && <span class="flow-arrow" aria-hidden="true">-></span>}
          </Fragment>
        ))
      }
    </div>

    <div class="cols">
      <div class="pack-list reveal delay-2">
        <h3>Reference packs loaded on demand</h3>
        <div class="grid">
          {
            packs.map(([name, note]) => (
              <div class="pack">
                <code>{name}</code>
                <p>{note}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="code-card reveal delay-3">
        <h3>Generated shape</h3>
        <pre><code>src/libs/catalog/features/product/
  services/
    product.model.ts
    product.service.ts
    product.mock-data.ts
  pages/
    list/list.component.ts
    detail/detail.component.ts
  routes.ts

tail chain:
  test -> review -> repair -> comments
  -> verify -> sdcorejs-ship(branch-ready) -> docs
  -> user-guide -> task tracker</code></pre>
      </div>
    </div>

    <div class="track-cta reveal delay-4">
      <div>
        Need the Angular-specific details? The dedicated track page keeps the
        autoId and E2E inspector guidance.
      </div>
      <a class="cta-link" href={`${base}/angular`}>
        Explore Angular Portal
        <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M5 12h14M13 5l7 7-7 7"
          />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .ap {
    background:
      linear-gradient(180deg, var(--c-bg-soft), var(--c-bg) 60%),
      var(--c-bg);
    border-block: 1px solid var(--c-border);
  }

  .head {
    max-width: 760px;
    margin-bottom: 42px;
  }

  .head code {
    background: var(--c-bg);
    padding: 2px 7px;
    border-radius: 6px;
    border: 1px solid var(--c-border);
    font-size: 0.92em;
    color: var(--c-blue-600);
  }

  .bullet {
    width: 6px;
    height: 6px;
    background: var(--c-orange-500);
    border-radius: 999px;
  }

  .flow {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    padding: 18px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .flow-step {
    padding: 8px 12px;
    background: var(--c-bg-soft);
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .flow-arrow {
    color: var(--c-text-muted);
  }

  .cols {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 880px) {
    .cols {
      grid-template-columns: 1fr;
    }
  }

  .pack-list,
  .code-card {
    padding: 24px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .pack-list h3,
  .code-card h3 {
    margin: 0 0 16px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 12px;
  }

  .pack {
    padding: 14px;
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
  }

  .pack code {
    color: var(--c-blue-600);
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    padding: 2px 6px;
    font-size: 0.84rem;
  }

  .pack p {
    margin: 8px 0 0;
    color: var(--c-text-soft);
    font-size: 0.9rem;
  }

  .code-card pre {
    margin: 0;
    padding: 16px;
    background: #0d1b2e;
    color: #e7ecf2;
    border-radius: 12px;
    overflow-x: auto;
  }

  .code-card code {
    color: inherit;
    background: none;
    padding: 0;
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .track-cta {
    margin-top: 24px;
    padding: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: var(--c-bg);
    border: 1px dashed var(--c-border-strong);
    border-radius: var(--radius-md);
    color: var(--c-text-soft);
  }

  @media (max-width: 720px) {
    .track-cta {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--c-blue-600);
    font-weight: 700;
    white-space: nowrap;
  }
</style>
