---
const steps = [
  {
    n: "01",
    title: "Add the marketplace",
    cmd: "/plugin marketplace add sdcorejs/sdcorejs-agent",
    note: "Claude Code reads the repo's .claude-plugin/marketplace.json.",
  },
  {
    n: "02",
    title: "Install the plugin",
    cmd: "/plugin install sdcorejs-agent@sdcorejs",
    note: "All 23 skills become dispatchable in your next session.",
  },
  {
    n: "03",
    title: "Try a prompt",
    cmd: "create Product CRUD in the catalog module",
    note: "Runtime-localized triggers. Brainstorming -> spec -> plan -> execute-plan.",
  },
];
---

<section id="install" class="install">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow"
        ><span class="bullet" aria-hidden="true"></span>Get started in 60 seconds</span
      >
      <h2>Install in Claude Code</h2>
      <p class="lead">
        The skill pack is distributed as a Claude Code plugin. No npm install,
        no compiler - once added, all skills dispatch automatically from each
        skill's <code>description</code> trigger.
      </p>
    </div>

    <ol class="steps">
      {
        steps.map((s, i) => (
          <li class={`step reveal delay-${i + 1}`}>
            <div class="step-head">
              <span class="step-n">{s.n}</span>
              <h3>{s.title}</h3>
            </div>
            <div class="step-cmd" data-copy={s.cmd}>
              <code>{s.cmd}</code>
              <button
                type="button"
                class="copy-btn"
                aria-label="Copy command"
                data-cmd={s.cmd}
              >
                <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
                  <rect
                    x="9"
                    y="9"
                    width="11"
                    height="11"
                    rx="2"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  />
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    d="M5 15V5a2 2 0 0 1 2-2h10"
                  />
                </svg>
              </button>
            </div>
            <p class="step-note">{s.note}</p>
          </li>
        ))
      }
    </ol>

    <div class="alt reveal delay-4">
      <h3>Prefer the source-of-truth path?</h3>
      <p>
        Clone the repo or add it as a git submodule. AGENTS.md works in Codex /
        Cursor, <code>.github/copilot-instructions.md</code> works in GitHub
        Copilot, <code>CLAUDE.md</code> works in Claude Code without the
        plugin.
      </p>
      <a
        class="btn btn-ghost"
        href="https://github.com/sdcorejs/sdcorejs-agent"
        target="_blank"
        rel="noreferrer"
      >
        Browse the repo on GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M7 17L17 7M9 7h8v8"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("click", (e) => {
    const target = e.target;
    if (!(target instanceof Element)) return;
    const btn = target.closest("[data-cmd]");
    if (!btn) return;
    const cmd = btn.getAttribute("data-cmd");
    if (!cmd) return;
    const done = () => {
      btn.classList.add("copied");
      setTimeout(() => btn.classList.remove("copied"), 1200);
    };
    if (navigator.clipboard?.writeText) {
      navigator.clipboard.writeText(cmd).then(done).catch(() => {});
      return;
    }
    const ta = document.createElement("textarea");
    ta.value = cmd;
    document.body.appendChild(ta);
    ta.select();
    try {
      document.execCommand("copy");
      done();
    } finally {
      document.body.removeChild(ta);
    }
  });
</script>

<style>
  .install {
    background: var(--c-bg);
  }

  .head {
    max-width: 720px;
    margin-bottom: 48px;
  }

  .head code {
    background: var(--c-bg-soft);
    padding: 2px 7px;
    border-radius: 6px;
    border: 1px solid var(--c-border);
    font-size: 0.92em;
    color: var(--c-blue-600);
  }

  .bullet {
    width: 6px;
    height: 6px;
    background: var(--c-orange-500);
    border-radius: 999px;
  }

  .steps {
    list-style: none;
    counter-reset: none;
    padding: 0;
    margin: 0 0 56px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .step {
    padding: 24px;
    background: var(--c-bg-soft);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    transition:
      transform 240ms var(--ease-spring),
      box-shadow 240ms var(--ease),
      border-color 240ms var(--ease);
  }

  .step:hover {
    transform: translateY(-4px);
    border-color: var(--c-blue-500);
    box-shadow: var(--shadow-md);
  }

  .step-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .step-n {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--c-text-on-brand);
    background: linear-gradient(135deg, var(--c-blue-500), var(--c-orange-500));
    padding: 5px 10px;
    border-radius: 8px;
  }

  .step-head h3 {
    font-size: 1.05rem;
    margin: 0;
  }

  .step-cmd {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 12px 14px;
    background: #0d1b2e;
    border-radius: 10px;
    color: #e7ecf2;
    margin-bottom: 10px;
  }

  .step-cmd code {
    font-size: 0.82rem;
    overflow-x: auto;
    white-space: nowrap;
  }

  .copy-btn {
    display: grid;
    place-items: center;
    padding: 6px;
    border-radius: 6px;
    color: rgba(231, 236, 242, 0.7);
    transition:
      background 180ms var(--ease),
      color 180ms var(--ease);
    flex-shrink: 0;
  }

  .copy-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
  }

  .copy-btn.copied {
    background: var(--c-success);
    color: #fff;
  }

  .step-note {
    margin: 0;
    color: var(--c-text-muted);
    font-size: 0.86rem;
  }

  .alt {
    padding: 28px;
    background: var(--c-bg-soft);
    border: 1px dashed var(--c-border-strong);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .alt h3 {
    margin-bottom: 8px;
    color: var(--c-text);
  }

  .alt p {
    margin: 0 0 18px;
    color: var(--c-text-soft);
  }

  .alt code {
    background: var(--c-bg);
    padding: 2px 7px;
    border-radius: 6px;
    border: 1px solid var(--c-border);
    font-size: 0.9em;
  }

  .alt .btn-ghost {
    background: var(--c-bg);
  }
</style>
