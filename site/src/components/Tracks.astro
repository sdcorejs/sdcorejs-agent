---
const tracks = [
  {
    id: "angular",
    name: "Angular Portal",
    status: "ready",
    statusLabel: "Available",
    tagline: "Backoffice portals with @sdcorejs/angular",
    description:
      "One Angular write-code orchestrator loads focused packs on demand: init portal, admin screens, module/entity CRUD, list/detail screens, and workflow or export actions.",
    bullets: [
      "Module -> Entity -> Screens orchestrator",
      "Side-drawer vs full-page layout decision",
      "Core UI first, with stable autoId guidance",
      "Runtime-localized labels and docs",
    ],
    accent: "blue",
    href: "#angular",
  },
  {
    id: "nestjs",
    name: "NestJS",
    status: "ready",
    statusLabel: "Available",
    tagline: "Modular APIs on @sdcorejs/nestjs",
    description:
      "NestJS write-code now targets @sdcorejs/nestjs v1.0.0 patterns: init project, always-on admin, bounded modules, CRUD entity stacks, and custom actions.",
    bullets: [
      "Simple vs enterprise profile-aware generation",
      "BaseEntity, BaseRepository, BaseService, BaseController",
      "Zod schemas + permission decorators",
      "Admin users, roles, and permissions always on",
    ],
    accent: "orange",
  },
  {
    id: "nextjs",
    name: "Next.js Public Sites",
    status: "ready",
    statusLabel: "Available",
    tagline: "Public sites with localization-ready SEO",
    description:
      "Next.js write-code dispatches 10 reference packs for site setup, theme, pages and blocks, SEO, OG previews, i18n, caching, responsive checks, contact forms, and content quality.",
    bullets: [
      "Language parity, no hardcoded strings",
      "30-min ISR + on-demand revalidate",
      "Real contact form, not a stub",
      "Content-quality + on-page SEO checker",
    ],
    accent: "purple",
  },
  {
    id: "product",
    name: "Product",
    status: "ready",
    statusLabel: "Available",
    tagline: "PRDs, user stories, AC, UAT, and traceability",
    description:
      "Product-track work records the human-readable truth: what the feature means, which stories exist, how requirements map to implementation, and where test evidence lives.",
    bullets: [
      "PRDs and user stories under product/",
      "Acceptance criteria and UAT checklists",
      "Requirement -> implementation -> test ledger",
      "Useful for PO/QC review before and after build",
    ],
    accent: "green",
  },
  {
    id: "design",
    name: "Design",
    status: "ready",
    statusLabel: "Available",
    tagline: "FE handoff from product user stories",
    description:
      "Design-track work turns user stories into screen flows, design specs, editable wireframes, and optional PNG previews for frontend implementation.",
    bullets: [
      "Story-to-screen mapping",
      "Wireframes and flow docs under design/",
      "PNG previews as exports, not source of truth",
      "Frontend reads this before generating UI",
    ],
    accent: "teal",
  },
  {
    id: "test",
    name: "Test",
    status: "ready",
    statusLabel: "Available",
    tagline: "Unit, integration, e2e, and UAT execution",
    description:
      "Test-track work writes and runs tests across Angular, NestJS, and Next.js. It can start from a plan, product stories, design handoff, or an autoId inspector export.",
    bullets: [
      "Stack + level auto-detection",
      "Unit, integration, e2e, and UAT",
      "Reads product and design docs for coverage",
      "Uses sdcorejs-test tdd mode for RED-first chunks",
    ],
    accent: "slate",
  },
];
---

<section id="tracks" class="tracks">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow"
        ><span class="bullet" aria-hidden="true"></span>One pack, six tracks</span
      >
      <h2>Pick the track your project needs</h2>
      <p class="lead">
        Tracks are the skills that create primary artifacts. The stack tracks
        write code; product, design, and test keep requirements, screen
        references, and verification evidence aligned.
      </p>
    </div>

    <div class="grid">
      {
        tracks.map((t, i) => (
          <article class={`card accent-${t.accent} status-${t.status} reveal delay-${i + 1}`}>
            <header>
              <span class={`status-pill ${t.status}`}>
                <span class="pill-dot" aria-hidden="true" />
                {t.statusLabel}
              </span>
              <h3>{t.name}</h3>
              <p class="tagline">{t.tagline}</p>
            </header>

            <p class="desc">{t.description}</p>

            <ul class="bullets">
              {t.bullets.map((b) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 12l5 5L20 7"
                    />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>

            {t.href ? (
              <a class="cta" href={t.href}>
                Explore the track
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 12h14M13 5l7 7-7 7"
                  />
                </svg>
              </a>
            ) : (
              <div class="cta cta-static" aria-disabled="true">
                Ready in the pack
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tracks {
    background: var(--c-bg);
  }

  .head {
    max-width: 720px;
    margin-bottom: 56px;
  }

  .bullet {
    width: 6px;
    height: 6px;
    background: var(--c-orange-500);
    border-radius: 999px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }

  .card {
    --accent-bg: var(--c-blue-100);
    --accent-fg: var(--c-blue-600);
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 28px 24px 24px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition:
      transform 280ms var(--ease-spring),
      box-shadow 260ms var(--ease),
      border-color 260ms var(--ease);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-fg);
    box-shadow: var(--shadow-md);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-fg), var(--accent-fg) 60%, transparent);
    opacity: 0;
    transition: opacity 260ms var(--ease);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card.accent-blue {
    --accent-bg: var(--c-blue-100);
    --accent-fg: var(--c-blue-600);
  }

  .card.accent-orange {
    --accent-bg: var(--c-orange-100);
    --accent-fg: var(--c-orange-600);
  }

  .card.accent-purple {
    --accent-bg: #efe9fc;
    --accent-fg: #7c3aed;
  }

  .card.accent-green {
    --accent-bg: #dcfce7;
    --accent-fg: #15803d;
  }

  .card.accent-teal {
    --accent-bg: #ccfbf1;
    --accent-fg: #0f766e;
  }

  .card.accent-slate {
    --accent-bg: #e2e8f0;
    --accent-fg: #475569;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent-fg);
    align-self: flex-start;
  }

  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: currentColor;
    animation: glow 1.8s ease-in-out infinite;
  }

  h3 {
    margin-top: 14px;
    color: var(--c-text);
  }

  .tagline {
    margin: 6px 0 0;
    color: var(--c-text-soft);
    font-size: 0.95rem;
  }

  .desc {
    margin: 18px 0 16px;
    color: var(--c-text-soft);
    font-size: 0.95rem;
  }

  .bullets {
    list-style: none;
    margin: 0 0 22px;
    padding: 0;
    display: grid;
    gap: 8px;
    color: var(--c-text);
    font-size: 0.92rem;
  }

  .bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .bullets svg {
    flex-shrink: 0;
    margin-top: 4px;
    color: var(--accent-fg);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--accent-bg);
    color: var(--accent-fg);
    font-size: 0.9rem;
    font-weight: 600;
    align-self: flex-start;
    transition:
      background 220ms var(--ease),
      color 220ms var(--ease),
      transform 200ms var(--ease-spring);
  }

  .cta:hover {
    background: var(--accent-fg);
    color: var(--c-text-on-brand);
    transform: translateX(3px);
  }

  .cta-static {
    cursor: default;
    pointer-events: none;
  }
</style>
