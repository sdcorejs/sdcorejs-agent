---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SDCoreJS Agent - Runtime-localized SDLC for AI coding agents",
  description = "SDCoreJS turns Claude Code, GitHub Copilot, Codex, and Cursor into accountable engineers for Angular, NestJS, and Next.js projects. It now ships global English-source skills plus deterministic E2E checks for the agent itself.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const ogImage = `${base}/icon.png`;
const canonical = `${Astro.site ?? ""}${base}/`.replace(/\/+$/, "/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#1976d2" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href={`${base}/icon.png`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="preload"
      as="image"
      href={`${base}/logo-text.png`}
      fetchpriority="high"
    />
  </head>
  <body>
    <slot />

    <script is:inline>
      (() => {
        const items = document.querySelectorAll(".reveal");
        if (!items.length || !("IntersectionObserver" in window)) {
          items.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        items.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
