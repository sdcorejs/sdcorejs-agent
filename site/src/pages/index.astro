---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const flowSteps = [
  ["01", "Khám phá", "Hiểu bối cảnh, tài liệu, ảnh, code, log, ràng buộc."],
  ["02", "Đặc tả", "Viết spec và acceptance criteria để người dùng duyệt."],
  ["03", "Kế hoạch", "Chốt file-by-file plan trước khi sinh code."],
  ["04", "Dispatch", "Chọn track executor hoặc parallel-dispatch khi an toàn."],
  ["05", "Kết thúc", "Test, review, repair, verify, docs, tasks, memories."],
];

const tracks = [
  ["Product", "PRD, user stories, AC, UAT, traceability"],
  ["Design", "Flow, wireframe, mockup, FE handoff"],
  ["Angular", "Portal, module, CRUD, screen, Core UI action"],
  ["NestJS", "Module, entity, API, business logic"],
  ["Next.js", "Landing page, SEO, i18n, caching"],
  ["Test", "Unit, integration, e2e, UAT evidence"],
  ["Generic", "Script, docs, config, unsupported-stack fallback"],
];

const tailSteps = [
  "sdcorejs-test",
  "sdcorejs-review",
  "repair-loop",
  "documentation: comments",
  "product ledger",
  "verify-before-done",
  "branch-ready",
  "auto-docs",
  "documentation: user guide",
  "task tracker",
  "memories",
  "handoff",
];

const contextInputs = [
  ["Ảnh / wireframe", "Màn hình mẫu, trạng thái form, flow duyệt, lỗi UX cần tránh."],
  ["PRD / nghiệp vụ", "Mục tiêu, actor, rule, priority, non-goals, acceptance criteria."],
  ["API docs", "Endpoint, payload, enum, error shape, permission, pagination, filter."],
  ["Code hiện có", "Module, route, service, component, shared Core UI pattern đang dùng."],
  ["Log / bug / test", "Evidence hiện tại để agent không đoán mò nguyên nhân."],
  ["Ràng buộc", "Style, i18n, auth, deploy, deadline, thứ không được thay đổi."],
];

const claudeSteps = [
  ["1", "Cài plugin", "/plugin marketplace add sdcorejs/sdcorejs-agent\n/plugin install sdcorejs-agent@sdcorejs"],
  ["2", "Mở project", "cd <target-project>\nclaude"],
  ["3", "Kiểm tra dispatch", "help\nlist skills\ncreate Product CRUD in catalog module"],
];

const codexSteps = [
  ["1", "Đưa repo vào workspace", "git clone https://github.com/sdcorejs/sdcorejs-agent.git\n# hoặc copy AGENTS.md + skills/_refs theo setup nội bộ"],
  ["2", "Mở target project", "cd <target-project>\ncodex"],
  ["3", "Kiểm tra skill flow", "Tôi muốn thêm màn hình quản lý hợp đồng.\nHãy dùng SDCoreJS flow: explore -> spec -> plan."],
];

const localChecks = [
  ["Skill mirror", "npm run check:skills"],
  ["Invariant e2e", "npm run test:e2e"],
  ["Doc site", "cd site && npm run build"],
  ["Manual smoke", "Mở deck, bấm Next/Back, kiểm tra chữ không tràn."],
];

const promptExamples = [
  ["Fix nhỏ", "Loại bỏ uuid, dùng generateUuid"],
  ["Module mới", "Add document-ai module"],
  [
    "Angular Portal + attachments",
    "Implement màn hình danh sách nội dung đợt thanh toán dựa vào design và PRD, API docs như sau, gắn quyền đầy đủ nhưng comment lại vì chưa khai báo vào file phân quyền",
  ],
];

const promptPrinciples = [
  ["Người dùng", "Chỉ cần nói intent ngắn gọn và đính kèm ảnh, PRD, API docs, file hoặc log khi có."],
  ["Agent", "Tự trigger sdcorejs-explore / project-context preflight để nạp IDE context, repo context, docs, memories và task tracker."],
  ["Safety", "Nếu context thiếu hoặc mâu thuẫn, agent phải hỏi lại trước khi spec/plan/code."],
];

const conflictExamples = [
  ["PRD nói required, API nói optional", "Agent phải hỏi nguồn nào là chuẩn trước khi viết spec."],
  ["Ảnh có nút Approve, permission matrix thiếu code", "Agent phải hỏi permission code hoặc đề xuất naming để duyệt."],
  ["API filter dùng status[], UI mock chỉ có một status", "Agent phải hỏi single-select hay multi-select."],
  ["Core UI pattern chưa rõ", "Agent phải scan code-map hoặc hỏi component chuẩn đang dùng."],
];
---

<Layout
  lang="vi"
  title="SDCoreJS Agent - Presenter deck"
  description="Deck trình bày SDCoreJS Agent: skill-driven SDLC, cài đặt Claude/Codex, test pack, và prompt mẫu cho Angular Portal Core UI."
>
  <div class="deck-app" data-deck>
    <header class="deck-header" aria-label="Deck header">
      <a class="brand" href={`${base}/`} aria-label="SDCoreJS Agent">
        <img src={`${base}/logo-text.png`} alt="SDCoreJS" />
      </a>
      <div class="deck-meta">
        <span data-section>SDCoreJS Agent</span>
        <b data-counter>1 / 18</b>
      </div>
    </header>

    <main class="slide-stage" aria-live="polite">
      <section class="deck-slide cover is-active" data-section-name="Mở đầu">
        <div class="slide-copy">
          <p class="kicker">Presenter deck</p>
          <h1>SDCoreJS Agent</h1>
          <h2>Luồng phát triển phần mềm bằng skill</h2>
          <p>
            Một bộ kỹ năng biến AI coding agent thành quy trình SDLC có context,
            approval gate, verification, tài liệu, task tracker và memory handoff.
          </p>
          <div class="metric-row">
            <span>23 skills</span>
            <span>7 tracks</span>
            <span>2 approval gates</span>
            <span>12 e2e checks</span>
          </div>
        </div>
        <div class="hero-panel" aria-hidden="true">
          <div class="orbit one"></div>
          <div class="orbit two"></div>
          <div class="orbit three"></div>
          <b>Context</b>
          <span>Spec</span>
          <span>Plan</span>
          <span>Dispatch</span>
          <span>Evidence</span>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Vấn đề">
        <div class="slide-copy narrow">
          <p class="kicker">Vấn đề cần giải</p>
          <h2>AI viết code nhanh, nhưng dễ thiếu quy trình</h2>
          <p>
            Nếu chỉ prompt trực tiếp vào code, agent có thể bỏ sót nghiệp vụ,
            quên context cũ, tự quyết khi tài liệu mâu thuẫn, hoặc claim xong
            khi chưa có evidence.
          </p>
        </div>
        <div class="three-up">
          <article>
            <b>Context rơi</b>
            <p>Ảnh, PRD, API docs, convention và task cũ không được nối lại.</p>
          </article>
          <article>
            <b>Scope trượt</b>
            <p>Không có spec/plan approval nên sinh code đúng cú pháp nhưng sai ý.</p>
          </article>
          <article>
            <b>Thiếu evidence</b>
            <p>Không có test, review, verify acceptance, branch-ready và handoff.</p>
          </article>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Input context">
        <div class="slide-copy">
          <p class="kicker">Cách dùng đúng</p>
          <h2>Prompt có thể ngắn, context đến từ IDE và attachment</h2>
          <p>
            Người dùng nói mục tiêu chính và đính kèm ảnh, PRD, API docs, log,
            issue, diff hoặc file liên quan. Khi request match skill,
            `sdcorejs-explore` tự nạp context cần thiết rồi hỏi lại nếu thiếu
            hoặc có mâu thuẫn.
          </p>
        </div>
        <div class="context-grid">
          {contextInputs.map(([title, text]) => (
            <article>
              <b>{title}</b>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Flow tổng quan">
        <div class="slide-copy">
          <p class="kicker">Mental model</p>
          <h2>Toàn bộ SDLC đi qua 5 nhịp chính</h2>
        </div>
        <div class="flow-row">
          {flowSteps.map(([no, title, text]) => (
            <article>
              <span>{no}</span>
              <b>{title}</b>
              <p>{text}</p>
            </article>
          ))}
        </div>
        <div class="image-strip" aria-hidden="true">
          <img src={`${base}/flow-discovery.svg`} alt="" />
          <img src={`${base}/flow-spec.svg`} alt="" />
          <img src={`${base}/flow-dispatch.svg`} alt="" />
          <img src={`${base}/flow-finish.svg`} alt="" />
          <img src={`${base}/flow-handoff.svg`} alt="" />
        </div>
      </section>

      <section class="deck-slide" data-section-name="Explore">
        <div class="split">
          <div class="slide-copy">
            <p class="kicker">Slide phụ 1</p>
            <h2>Explore: đọc trước khi trả lời</h2>
            <p>
              `project-context.md` là recipe đọc context. `.sdcorejs/summary.md`
              là project brief sinh trong target project. Explore cũng đọc docs,
              memories, specs/plans, task tracker và persona khi có.
            </p>
          </div>
          <div class="stack-list">
            <article><b>Đầu vào</b><span>Request, file đang mở, ảnh, tài liệu, git state.</span></article>
            <article><b>Agent làm</b><span>Map project, detect track, tìm blockers.</span></article>
            <article><b>Kết quả</b><span>Scope hiểu đúng, câu hỏi rõ, không nhảy vào code sớm.</span></article>
          </div>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Spec gate">
        <div class="split reverse">
          <div class="gate-card">
            <span>Gate 1</span>
            <b>sdcorejs-spec</b>
            <p>Problem, goals, non-goals, architecture, file structure, acceptance criteria, risk.</p>
          </div>
          <div class="slide-copy">
            <p class="kicker">Slide phụ 2</p>
            <h2>Spec là hợp đồng nghiệp vụ</h2>
            <p>
              Agent tự review spec, gửi người dùng duyệt, rồi mới snapshot spec
              đã approve. Im lặng không được tính là approve.
            </p>
          </div>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Plan gate">
        <div class="split">
          <div class="slide-copy">
            <p class="kicker">Slide phụ 3</p>
            <h2>Plan khóa cách làm trước khi sinh code</h2>
            <p>
              Plan là danh sách bước theo file, dependency, risk và verification.
              Sau plan approval, execute-plan luôn hỏi chạy sequential hay parallel.
            </p>
          </div>
          <div class="mode-grid">
            <article>
              <b>Sequential</b>
              <p>Chạy từng track theo thứ tự để giảm rủi ro khi scope liên quan chặt.</p>
            </article>
            <article>
              <b>Parallel</b>
              <p>Chỉ fan-out khi `sdcorejs-parallel-dispatch` đánh giá an toàn.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Dispatch">
        <div class="slide-copy">
          <p class="kicker">Track dispatch</p>
          <h2>Mỗi loại việc có executor riêng</h2>
        </div>
        <div class="track-grid">
          {tracks.map(([title, text]) => (
            <article>
              <span>{title.slice(0, 1)}</span>
              <b>{title}</b>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Finish gate">
        <div class="slide-copy">
          <p class="kicker">Finish gate</p>
          <h2>Không nói “xong” nếu chưa có evidence</h2>
          <p>
            Sau code generation, tail chain bắt buộc chạy để kiểm thử, review,
            sửa lỗi, verify acceptance và ghi lại tri thức.
          </p>
        </div>
        <div class="tail-grid">
          {tailSteps.map((item, index) => (
            <article>
              <span>{index + 1}</span>
              <b>{item}</b>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Memory">
        <div class="split">
          <div class="slide-copy">
            <p class="kicker">Handoff</p>
            <h2>Phiên sau không bắt đầu từ số không</h2>
            <p>
              Auto-docs ghi tóm tắt phiên. Task tracker giữ TODO sống. Memories
              lưu constraint, decision, pattern và correction dài hạn.
            </p>
          </div>
          <div class="memory-lanes">
            <article><b>auto-docs</b><span>.sdcorejs/docs/&lt;track&gt;/</span></article>
            <article><b>task tracker</b><span>.sdcorejs/tasks/current-session.md</span></article>
            <article><b>memories</b><span>.sdcorejs/memories/&lt;track&gt;/</span></article>
            <article><b>persona</b><span>.sdcorejs/persona.md</span></article>
          </div>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Claude install">
        <div class="slide-copy">
          <p class="kicker">Cài đặt</p>
          <h2>Cài và thử trên Claude Code</h2>
        </div>
        <div class="command-grid">
          {claudeSteps.map(([no, title, code]) => (
            <article>
              <span>{no}</span>
              <b>{title}</b>
              <pre><code>{code}</code></pre>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Codex install">
        <div class="slide-copy">
          <p class="kicker">Cài đặt</p>
          <h2>Dùng trong Codex, Cursor, Copilot-compatible tools</h2>
          <p>
            Các tool đọc `AGENTS.md` sẽ nhận workflow, rule, reference loading
            và session-start discipline của skill pack.
          </p>
        </div>
        <div class="command-grid">
          {codexSteps.map(([no, title, code]) => (
            <article>
              <span>{no}</span>
              <b>{title}</b>
              <pre><code>{code}</code></pre>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Test pack">
        <div class="slide-copy">
          <p class="kicker">Kiểm thử skill pack</p>
          <h2>Test ở repo agent trước khi đưa vào project thật</h2>
        </div>
        <div class="check-grid">
          {localChecks.map(([title, command]) => (
            <article>
              <b>{title}</b>
              <code>{command}</code>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Angular setup">
        <div class="slide-copy">
          <p class="kicker">Áp dụng thực tế</p>
          <h2>Vận dụng vào Angular Portal dùng Core UI</h2>
          <p>
            Mục tiêu không phải “generate component” đơn lẻ. Mục tiêu là agent
            hiểu module, route, permission, API, Core UI convention, autoId,
            test flow và tài liệu bàn giao.
          </p>
        </div>
        <div class="context-grid compact">
          <article><b>Code-map</b><p>Module, routes, service, DTO, shared UI pattern.</p></article>
          <article><b>Core UI first</b><p>Dùng component `@sdcorejs/angular` trước khi tự dựng UI.</p></article>
          <article><b>autoId</b><p>Selector ổn định cho review và e2e inspector.</p></article>
          <article><b>Permission</b><p>VIEW, CREATE, UPDATE, APPROVE, EXPORT theo matrix.</p></article>
          <article><b>Tests</b><p>Unit/integration/e2e theo acceptance criteria.</p></article>
          <article><b>Docs</b><p>User guide, auto-docs, task tracker, memories.</p></article>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Prompt mẫu">
        <div class="slide-copy">
          <p class="kicker">Prompt mẫu</p>
          <h2>Prompt nên đơn giản như cách mình làm thật</h2>
          <p>
            Không cần nhắc agent chạy explore/spec/plan trong mỗi prompt.
            Skill dispatcher và `sdcorejs-explore` phải tự làm phần nạp context
            khi bắt đầu thực thi.
          </p>
        </div>
        <div class="prompt-layout">
          <div class="prompt-examples">
            {promptExamples.map(([label, text]) => (
              <article>
                <span>{label}</span>
                <b>{text}</b>
              </article>
            ))}
          </div>
          <div class="prompt-principles">
            {promptPrinciples.map(([label, text]) => (
              <article>
                <span>{label}</span>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="deck-slide" data-section-name="Khi thiếu context">
        <div class="slide-copy">
          <p class="kicker">Safety behavior</p>
          <h2>Khi thiếu hoặc mâu thuẫn, agent phải hỏi lại</h2>
        </div>
        <div class="conflict-grid">
          {conflictExamples.map(([problem, response]) => (
            <article>
              <b>{problem}</b>
              <p>{response}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="deck-slide" data-section-name="Demo script">
        <div class="slide-copy">
          <p class="kicker">Cách demo</p>
          <h2>Một luồng present gọn trong 10 phút</h2>
        </div>
        <div class="demo-steps">
          <article><span>1</span><b>Show problem</b><p>Vì sao prompt-only không đủ.</p></article>
          <article><span>2</span><b>Show SDLC flow</b><p>Explore, spec, plan, dispatch, finish.</p></article>
          <article><span>3</span><b>Show install/test</b><p>Claude, Codex, local invariant checks.</p></article>
          <article><span>4</span><b>Show Angular prompt</b><p>Prompt ngắn + ảnh/PRD/API docs đính kèm.</p></article>
          <article><span>5</span><b>Show safety</b><p>Agent hỏi lại khi context thiếu hoặc mâu thuẫn.</p></article>
        </div>
      </section>

      <section class="deck-slide closing" data-section-name="Kết luận">
        <div class="slide-copy narrow">
          <p class="kicker">Kết luận</p>
          <h2>Skill pack biến AI thành teammate có quy trình</h2>
          <p>
            Không chỉ sinh code: agent phải hiểu context, xin approval đúng chỗ,
            thực thi theo track, kiểm chứng bằng evidence, rồi để lại tri thức
            cho phiên sau.
          </p>
          <div class="closing-band">
            <b>SDCoreJS Agent</b>
            <span>Context -> Spec -> Plan -> Execute -> Verify -> Remember</span>
          </div>
        </div>
        <figure class="summary-map">
          <img
            src={`${base}/skill-flow-summary.png`}
            alt="Sơ đồ tổng quan luồng phát triển phần mềm bằng skill của SDCoreJS Agent"
          />
        </figure>
      </section>
    </main>

    <footer class="deck-controls" aria-label="Slide controls">
      <button type="button" class="nav-button" data-prev>Back</button>
      <div class="progress" aria-hidden="true"><span data-progress></span></div>
      <button type="button" class="nav-button primary" data-next>Next</button>
    </footer>
  </div>

  <script is:inline>
    (() => {
      const deck = document.querySelector("[data-deck]");
      if (!deck) return;

      const slides = Array.from(deck.querySelectorAll(".deck-slide"));
      const counter = deck.querySelector("[data-counter]");
      const section = deck.querySelector("[data-section]");
      const progress = deck.querySelector("[data-progress]");
      const prev = deck.querySelector("[data-prev]");
      const next = deck.querySelector("[data-next]");
      let index = 0;

      const render = () => {
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.classList.toggle("is-active", active);
          slide.setAttribute("aria-hidden", active ? "false" : "true");
        });

        if (counter) counter.textContent = `${index + 1} / ${slides.length}`;
        if (section) section.textContent = slides[index]?.dataset.sectionName || "SDCoreJS Agent";
        if (progress) progress.style.inlineSize = `${((index + 1) / slides.length) * 100}%`;
        if (prev) prev.toggleAttribute("disabled", index === 0);
        if (next) next.textContent = index === slides.length - 1 ? "Restart" : "Next";
      };

      prev?.addEventListener("click", () => {
        index = Math.max(0, index - 1);
        render();
      });

      next?.addEventListener("click", () => {
        index = index === slides.length - 1 ? 0 : index + 1;
        render();
      });

      const blockScroll = (event) => event.preventDefault();
      window.addEventListener("wheel", blockScroll, { passive: false });
      window.addEventListener("touchmove", blockScroll, { passive: false });

      render();
    })();
  </script>
</Layout>

<style>
  :global(html),
  :global(body) {
    block-size: 100%;
    overflow: hidden;
  }

  :global(body) {
    background: #f5f8fc;
  }

  .deck-app {
    --deck-ink: #0d2748;
    --deck-soft: #52637a;
    --deck-line: #d8e2ef;
    --deck-blue: #1976d2;
    --deck-green: #16875c;
    --deck-orange: #f97316;
    --deck-violet: #6254d9;
    block-size: 100dvh;
    display: grid;
    grid-template-rows: 58px minmax(0, 1fr) 68px;
    color: var(--deck-ink);
    background:
      linear-gradient(90deg, rgba(25, 118, 210, 0.08) 0 1px, transparent 1px 80px),
      linear-gradient(180deg, rgba(25, 118, 210, 0.06) 0 1px, transparent 1px 80px),
      #f5f8fc;
  }

  .deck-header,
  .deck-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-inline: clamp(18px, 3vw, 40px);
    background: rgba(255, 255, 255, 0.9);
    border-color: var(--deck-line);
    border-style: solid;
    backdrop-filter: blur(12px);
  }

  .deck-header {
    border-width: 0 0 1px;
  }

  .deck-controls {
    border-width: 1px 0 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    min-inline-size: 0;
  }

  .brand img {
