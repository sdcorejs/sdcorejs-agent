---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const packs = [
  ["init-portal", "Portal shell, environments, Core UI setup"],
  ["admin-screens", "Account, role, and permission management"],
  ["init-module", "Feature module boundary and route registration"],
  ["init-entity", "Full CRUD stack and focused tests"],
  ["screen-list", "Table, filters, paging, bulk actions"],
  ["screen-detail", "CREATE / UPDATE / DETAIL states and form refinement"],
  ["actions", "Workflow, export, custom side effects"],
];

const platforms = [
  {
    name: "Claude Code",
    tag: "Plugin",
    code: "/plugin marketplace add sdcorejs/sdcorejs-agent\n/plugin install sdcorejs-agent@sdcorejs",
    prompt: "create Product CRUD in the catalog module",
  },
  {
    name: "Codex / Cursor",
    tag: "AGENTS.md",
    code: "codex\n# AGENTS.md is picked up automatically",
    prompt: "add an approval action to the order detail screen",
  },
  {
    name: "GitHub Copilot",
    tag: "Chat mode",
    code: "# Select the SDCoreJS SDLC chat mode\n@workspace",
    prompt: "write Playwright E2E for the Product list screen",
  },
];
---

<Layout
  title="Angular Portal - SDCoreJS SDLC Agent"
  description="The Angular Portal track: generate Core UI first backoffice portals through clarify, spec, plan, write-code, review, and E2E verification."
>
  <Nav />
  <main id="top">
    <section class="track-hero">
      <div class="container">
        <a class="back reveal" href={`${base}/#tracks`}>Back to tracks</a>
        <span class="eyebrow reveal"
          ><span class="bullet" aria-hidden="true"></span>Angular Portal</span
        >
        <h1 class="reveal">Core UI first portal generation</h1>
        <p class="lead reveal">
          The Angular track turns confirmed requirements into backoffice modules,
          list/detail screens, workflow actions, tests, review findings, and
          user-guide updates. It is a single orchestrator that loads reference
          packs on demand instead of flooding the model with every rule up front.
        </p>
      </div>
    </section>

    <section class="packs">
      <div class="container">
        <h2 class="reveal">Reference packs</h2>
        <div class="pack-grid">
          {
            packs.map(([name, note], i) => (
              <article class={`pack reveal delay-${(i % 4) + 1}`}>
                <code>{name}</code>
                <p>{note}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="inspector" id="e2e">
      <div class="container">
        <div class="head reveal">
          <span class="eyebrow"
            ><span class="bullet" aria-hidden="true"></span>E2E inspector loop</span
          >
          <h2>Selectors are input, not intent</h2>
          <p class="lead">
            The `sd-autoid-inspector` export helps the agent find stable
            selectors, but the E2E skill still gates on flows, assertions, test
            data, auth, and environment. That keeps generated tests useful
            instead of producing a selector dump.
          </p>
        </div>

        <div class="loop">
          <article class="step reveal delay-1">
            <b>1. Review</b>
            <p>Review flags missing `autoId` on interactive Core UI elements.</p>
          </article>
          <article class="step reveal delay-2">
            <b>2. Export</b>
            <p>The inspector exports selectors, XPath, control type, and runtime state.</p>
          </article>
          <article class="step reveal delay-3">
            <b>3. Gate</b>
            <p>Brainstorm, clarify, and plan lock the actual cases before tests are written.</p>
          </article>
          <article class="step reveal delay-4">
            <b>4. Verify</b>
            <p>Playwright, Cypress, or Robot Framework specs run before handoff.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="platforms">
      <div class="container">
        <h2 class="reveal">Use it from the agent you already have</h2>
        <div class="platform-grid">
          {
            platforms.map((item, i) => (
              <article class={`platform reveal delay-${i + 1}`}>
                <div class="platform-head">
                  <h3>{item.name}</h3>
                  <span>{item.tag}</span>
                </div>
                <pre><code>{item.code}</code></pre>
                <p><b>Prompt:</b> {item.prompt}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .container {
    width: min(var(--container), 100% - 40px);
    margin-inline: auto;
  }

  .track-hero {
    padding: clamp(40px, 8vw, 84px) 0 36px;
    background: linear-gradient(180deg, var(--c-blue-100), transparent 78%);
  }

  .back {
    display: inline-block;
    margin-bottom: 14px;
    color: var(--c-text-soft);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .back:hover {
    color: var(--c-blue-600);
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.08;
    margin: 12px 0 0;
  }

  h2 {
    margin-bottom: 20px;
  }

  .bullet {
    width: 6px;
    height: 6px;
    background: var(--c-orange-500);
    border-radius: 999px;
  }

  .packs,
  .platforms {
    background: var(--c-bg);
  }

  .pack-grid,
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
  }

  .pack,
  .platform,
  .step {
    padding: 22px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .pack code {
    color: var(--c-blue-600);
    background: var(--c-blue-100);
    border-radius: 6px;
    padding: 2px 7px;
    font-weight: 700;
  }

  .pack p,
  .step p,
  .platform p {
    margin: 10px 0 0;
    color: var(--c-text-soft);
  }

  .inspector {
    background: var(--c-bg-soft);
    border-block: 1px solid var(--c-border);
  }

  .head {
    max-width: 780px;
    margin-bottom: 28px;
  }

  .loop {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .step b {
    color: var(--c-blue-600);
  }

  .platform-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .platform-head h3 {
    margin: 0;
  }

  .platform-head span {
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--c-orange-100);
    color: var(--c-orange-600);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .platform pre {
    margin: 0;
    padding: 14px;
    background: #0d1b2e;
    color: #e7ecf2;
    border-radius: 10px;
    overflow-x: auto;
  }

  .platform code {
    color: inherit;
    background: none;
    padding: 0;
    font-size: 0.84rem;
  }
</style>
