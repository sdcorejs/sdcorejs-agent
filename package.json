{
  "name": "sdcorejs-agent",
  "version": "0.2.0",
  "description": "An orchestrated SDLC for AI coding agents — Angular Portal, NestJS, and Next.js stacks with explicit approval gates between every phase. Works in Claude Code, GitHub Copilot, and Codex.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "files": [
    "skills",
    "CLAUDE.md",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sdcorejs",
    "sdlc-agent",
    "claude-code",
    "github-copilot",
    "codex",
    "angular",
    "nestjs",
    "nextjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "scripts": {
    "sync:skills": "bash .claude/sync-skills.sh",
    "check:skills": "bash .claude/sync-skills.sh --check",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "lefthook": "^1.7.0"
  }
}
